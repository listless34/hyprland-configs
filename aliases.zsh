# file to put aliases of zsh
#

alias ls="exa -al"
alias y="yay -S"
alias ys="yay -Ss"
alias yc="yay -Scc"
alias yr="yay -Rns"
alias update="yay -Syu"
alias begin="start-hyprland"
alias p="sudo pacman -S --needed"
alias ps="pacman -Ss"
alias tls="tmux ls"
alias tm="tmux"
alias ta="tmux attach"
alias cr="cargo run"
alias ct="cargo test"
alias cat="bat"
alias fp='flatpak --installation=extra'
alias ga="git add ."
alias gi="git init"
alias gs="git status"
