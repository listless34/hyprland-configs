###################
### KEYBINDINGS ###
###################

$mainMod = SUPER

# Spawn terminal (kitty)
bind = $mainMod, Return, exec, kitty

# Kill active windows
bind = $mainMod, W, killactive,

# shutdown hyprland
bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit

# Open file manager (dolphin)
bind = $mainMod, E, exec, $fileManager

# Open brower (Brave)
bind = $mainMod, Q, exec, $browser

# show desktop 
bind = $mainMod + SHIFT, D, exec, $HOME/.config/scripts/showdesktop.sh

# Make window float
bind = $mainMod, V, togglefloating,

# Opens rofi
bind = $mainMod, D, exec, $menu
bind = $mainMod + Control_L, D, exec, $HOME/.config/scripts/convenience/rofi_wallpaper.sh

bind = $mainMod, P, pseudo, # dwindle
bind = $mainMod + SHIFT, J, togglesplit, # dwindle

# logout menu
bind = $mainMod + SHIFT, W, exec, $logoutMenu 

# Refresh waybar
bind = $mainMod, R, exec, $waybar
bind = $mainMod + SHIFT_L, R, exec, $HOME/.config/scripts/convenience/kill_waybar.sh 

# Lock screen
bind = $mainMod + Control_L, L, exec, $HOME/.config/scripts/convenience/hyprlockWall.sh

# Screenshot tool
bind = , Print, exec, zsh -c 'grimblast copysave screen "$HOME/Pictures/Screenshots/$(date "+%Y-%m-%d_%H-%M-%S").png"'
bind = $mainMod, Print, exec, zsh -c 'grimblast save area "$HOME/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png"'
bind = $mainMod + SHIFT_L, S, exec, grimblast copy area 

# Color picker
bind = $mainMod + SHIFT_L, P, exec, hyprpicker -a

# Cycle through wallpapers
bind = $mainMod + SHIFT_L, M, exec, $HOME/.config/scripts/wallpapers/nextWallpaper.sh
bind = $mainMod + SHIFT_L, N, exec, $HOME/.config/scripts/wallpapers/prevWallpaper.sh
bind = $mainMod + Control_L, C, exec, $HOME/.config/scripts/convenience/cycleWallpaper.sh

# fullscreen and pinning
bind = $mainMod, F, fullscreen,
bind = $mainMod + SHIFT_L, V, pin,

# Swap windows
bind = $mainMod + SHIFT_L, h, movewindow, l
bind = $mainMod + SHIFT_L, l, movewindow, r
bind = $mainMod + SHIFT_L, j, movewindow, u
bind = $mainMod + SHIFT_L, k, movewindow, d

# Move focus with mainMod + arrow keys
bind = $mainMod, h, movefocus, l
bind = $mainMod, l, movefocus, r
bind = $mainMod, j, movefocus, u
bind = $mainMod, k, movefocus, d

# Switch workspaces with mainMod + [0-9]
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# Example special workspace (scratchpad)
bind = $mainMod, S, togglespecialworkspace, magic
bind = $mainMod SHIFT_R, S, movetoworkspace, special:magic

# Scroll through existing workspaces with mainMod + scroll
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# Laptop multimedia keys for volume and LCD brightness
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindel = ,XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 5%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 5%-

# Requires playerctl
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

bind = , XF86MonBrightnessUp, exec, brightnessctl s +5%
bind = , XF86MonBrightnessDown, exec, brightnessctl s 5%-

